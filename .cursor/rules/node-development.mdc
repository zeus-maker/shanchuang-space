## 常用节点内部模式

### 标签双击编辑
```js
const isEditingLabel = ref(false)
const editingLabelValue = ref('')
const labelInputRef = ref(null)

const startEditLabel = () => {
  editingLabelValue.value = props.data?.label || ''
  isEditingLabel.value = true
  nextTick(() => { labelInputRef.value?.focus(); labelInputRef.value?.select() })
}
const finishEditLabel = () => {
  const v = editingLabelValue.value.trim()
  if (v) updateNode(props.id, { label: v })
  isEditingLabel.value = false
}
```

### 动态尺寸变化后通知 Vue Flow
```js
watch(() => props.data?.someStateKey, () =>
  nextTick(() => updateNodeInternals(props.id))
)
```

### 流式 LLM 调用（streaming）
```js
import { streamChatCompletions } from '../../api/chat'
import { DEFAULT_CHAT_MODEL } from '../../config/models'

let abortCtrl = null
onUnmounted(() => abortCtrl?.abort())

const handleGenerate = async () => {
  abortCtrl = new AbortController()
  updateNode(props.id, { status: 'loading' })
  let fullText = ''
  try {
    for await (const chunk of streamChatCompletions(
      { model: localModel.value, messages: [...] },
      abortCtrl.signal
    )) {
      fullText += chunk
    }
    updateNode(props.id, { status: 'done', result: fullText })
  } catch (err) {
    if (err.name === 'AbortError') updateNode(props.id, { status: 'idle' })
    else updateNode(props.id, { status: 'error' })
  } finally {
    abortCtrl = null
  }
}
```

### 批量创建节点并打组
```js
import { addNodes, addCanvasGroup, updateCanvasGroup,
         startBatchOperation, endBatchOperation } from '../../stores/canvas'

startBatchOperation()
const newIds = addNodes(specs, false)   // false = 不单独保存历史
endBatchOperation()

// 等待 Vue 写入后再计算打组边界
await new Promise(r => setTimeout(r, 120))
if (newIds.length >= 2) {
  const gid = addCanvasGroup(newIds)
  if (gid) updateCanvasGroup(gid, { label: '自定义分组名' })
}
```

