# 火山引擎 Ark：生图 Seedream、视频 Seedance 1.5 Pro 直连时使用
# 复制为 .env 后填写；修改后需重启 dev server（npm run dev）
VITE_VOLCENGINE_API_KEY=

# 推荐写完整推理 Base（北京）；也可只写域名，程序会自动补全 /api/v3
VITE_VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 可选，默认 /images/generations（与官方「图片生成 API」OpenAI 兼容路径一致）
# VITE_VOLCENGINE_IMAGE_PATH=

# 本地媒体缓存：前端请求相对路径 /api/media 时，开发环境需同时运行 npm run server（默认 8787），或由 Vite 代理
# 若媒体服务部署在其它域名，填写完整 origin，例如 https://your-host:8787
# VITE_MEDIA_API_URL=

# 服务端落盘目录（仅 node server/index.mjs 读取，非 Vite 变量）：默认 <项目根>/uploads
# MEDIA_ROOT=

# Sora2 图生视频首帧：data URL 需经媒体服务上传到火山 TOS 后得到公网 URL（见 README）
# VOLCENGINE_TOS_ACCESS_KEY_ID=
# VOLCENGINE_TOS_SECRET_ACCESS_KEY=
# VOLCENGINE_TOS_BUCKET=
# VOLCENGINE_TOS_REGION=cn-beijing
# VOLCENGINE_TOS_ENDPOINT=
# VOLCENGINE_TOS_PUBLIC_BASE_URL=
